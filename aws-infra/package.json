{
  "name": "aws-infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cdk:app": "node ./node_modules/ts-node/dist/bin.js --prefer-ts-exts bin/app.ts",
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth && node bin/generate-infra-artifacts.mjs",
    "diff": "cdk diff",
    "postinstall": "node scripts/patch-cdk-brace-expansion.cjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "aws-cdk": "^2.245.0",
    "brace-expansion": "5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.2"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.245.0",
    "constructs": "^10.4.2"
  }
}
