[Unit]
Description=aws-infra-dashboard FastAPI (serves /api for synthesized CDK metadata)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Change User and paths to match your clone (e.g. /home/ec2-user/aws-experimentation)
User=ec2-user
WorkingDirectory=/opt/aws-experimentation/aws-infra-dashboard/backend
ExecStart=/opt/aws-experimentation/aws-infra-dashboard/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
